<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crittercare.controller.CareLogsController"
      styleClass="view-root" spacing="16">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- ── Stat cards ─────────────────────────────────────────────── -->
    <HBox spacing="16">

        <VBox styleClass="stat-card-sm" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Today's Logs" styleClass="card-label"/>
                    <Label fx:id="todaysLogsLabel" text="—" styleClass="card-value"/>
                    <Label text="↑ 14% from yesterday" styleClass="card-sub"/>
                </VBox>
                <Label text="📋" style="-fx-font-size: 24px;"/>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card-sm" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Feedings Completed" styleClass="card-label"/>
                    <Label fx:id="feedingsLabel" text="—" styleClass="card-value card-value-success"/>
                    <Label text="100% of scheduled" styleClass="card-sub"/>
                </VBox>
                <Label text="🍖" style="-fx-font-size: 24px;"/>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card-sm" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Sanitation Tasks" styleClass="card-label"/>
                    <Label fx:id="sanitationLabel" text="—" styleClass="card-value"/>
                    <Label text="2 pending" styleClass="card-sub-warning"/>
                </VBox>
                <Label text="🧹" style="-fx-font-size: 24px;"/>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card-sm stat-card-alert" HBox.hgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Pending Interventions" styleClass="card-label"/>
                    <Label fx:id="pendingLabel" text="—" styleClass="card-value card-value-alert"/>
                    <Label text="Require attention" styleClass="card-sub-danger"/>
                </VBox>
                <Label text="🚑" style="-fx-font-size: 24px;"/>
            </HBox>
        </VBox>

    </HBox>

    <!-- ── Toolbar ────────────────────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
        <TextField fx:id="searchField" promptText="🔍  Search logs, animals, staff…"
                   prefWidth="260" styleClass="search-field"/>
        <ComboBox fx:id="activityFilter" promptText="Log Type" prefWidth="150"
                  styleClass="filter-combo"/>
        <ComboBox fx:id="statusFilter" promptText="All Statuses" prefWidth="140"
                  styleClass="filter-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Log Entry" styleClass="btn-primary" onAction="#showAddLogDialog"/>
    </HBox>

    <!-- ── Section heading ────────────────────────────────────────── -->
    <Label text="Recent Care Logs"
           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>

    <!-- ── Logs table ─────────────────────────────────────────────── -->
    <TableView fx:id="logsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colTimestamp" text="Time"             prefWidth="130"/>
            <TableColumn fx:id="colSubject"   text="Animal / Enclosure" prefWidth="160"/>
            <TableColumn fx:id="colActivity"  text="Activity Type"    prefWidth="130"/>
            <TableColumn fx:id="colStaff"     text="Staff Member"     prefWidth="140"/>
            <TableColumn fx:id="colStatus"    text="Status"           prefWidth="110"/>
            <TableColumn fx:id="colNotes"     text="Notes"            prefWidth="220"/>
            <TableColumn fx:id="colFollowUp"  text="Follow-Up"        prefWidth="90"/>
            <TableColumn fx:id="colActions"   text="Actions"          prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="No care logs found" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

</VBox>
