<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crittercare.controller.EnclosuresController"
      styleClass="view-root" spacing="16">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- ── Stat cards ─────────────────────────────────────────────── -->
    <HBox spacing="16">

        <!-- Total Enclosures -->
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Total Enclosures" styleClass="card-label"/>
                    <Label fx:id="totalEnclosuresLabel" text="—" styleClass="card-value"/>
                    <Label text="All habitats" styleClass="card-sub-ok"/>
                </VBox>
                <VBox styleClass="stat-icon-circle-teal" alignment="CENTER"
                      minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                    <Label text="⊞" styleClass="stat-icon stat-icon-teal"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Occupied Enclosures -->
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Occupied" styleClass="card-label"/>
                    <Label fx:id="occupiedEnclosuresLabel" text="—" styleClass="card-value card-value-success"/>
                    <Label fx:id="occupancyRateLabel" text="" styleClass="card-sub-ok"/>
                </VBox>
                <VBox styleClass="stat-icon-circle-green" alignment="CENTER"
                      minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                    <Label text="🐾" styleClass="stat-icon stat-icon-green"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Cleaning Due -->
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Cleaning Due" styleClass="card-label"/>
                    <Label fx:id="cleaningDueCountLabel" text="—" styleClass="card-value card-value-warning"/>
                    <Label text="Need attention" styleClass="card-sub-warning"/>
                </VBox>
                <VBox styleClass="stat-icon-circle-amber" alignment="CENTER"
                      minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                    <Label text="🧹" styleClass="stat-icon stat-icon-amber"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Critical Issues -->
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Critical Issues" styleClass="card-label"/>
                    <Label fx:id="criticalIssuesLabel" text="—" styleClass="card-value card-value-alert"/>
                    <Label text="Immediate action required" styleClass="card-sub-danger"/>
                </VBox>
                <VBox styleClass="stat-icon-circle-red" alignment="CENTER"
                      minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                    <Label text="⚠" styleClass="stat-icon stat-icon-red"/>
                </VBox>
            </HBox>
        </VBox>

    </HBox>

    <!-- ── Cleanliness score + toolbar row ────────────────────────── -->
    <HBox spacing="16" alignment="CENTER_LEFT">

        <!-- Overall Cleanliness Score (compact) -->
        <VBox styleClass="panel" spacing="6" minWidth="220">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Overall Cleanliness Score" styleClass="card-label" HBox.hgrow="ALWAYS"/>
                <Label fx:id="overallCleanlinessLabel" text="—%" styleClass="trend-score-green"/>
            </HBox>
            <ProgressBar fx:id="cleanlinessScoreBar" progress="0.88"
                         maxWidth="Infinity" styleClass="trend-bar"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Toolbar -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍  Search enclosures…"
                       prefWidth="240" styleClass="search-field"/>
            <ComboBox fx:id="habitatFilter" promptText="All Habitats" prefWidth="160"
                      styleClass="filter-combo"/>
            <Button fx:id="btnClean" text="Clean Selected" styleClass="btn-secondary"
                    onAction="#cleanSelectedEnclosure"/>
            <Button text="+ Add Enclosure" styleClass="btn-primary"
                    onAction="#showAddEnclosureDialog"/>
        </HBox>
    </HBox>

    <!-- ── Enclosures table ───────────────────────────────────────── -->
    <Label text="Enclosures Overview"
           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>

    <TableView fx:id="enclosuresTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colName"        text="Enclosure"     prefWidth="180"/>
            <TableColumn fx:id="colHabitat"     text="Habitat Type"  prefWidth="140"/>
            <TableColumn fx:id="colCapacity"    text="Capacity"      prefWidth="75"/>
            <TableColumn fx:id="colOccupancy"   text="Animals"       prefWidth="75"/>
            <TableColumn fx:id="colCleanliness" text="Cleanliness"   prefWidth="160"/>
            <TableColumn fx:id="colLastCleaned" text="Last Cleaned"  prefWidth="140"/>
            <TableColumn fx:id="colStatus"      text="Status"        prefWidth="120"/>
            <TableColumn fx:id="colActions"     text="Actions"       prefWidth="110"/>
        </columns>
        <placeholder>
            <Label text="No enclosures found" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status bar ─────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="enclosureCountLabel" text="" styleClass="status-text"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="cleaningDueLabel"    text="" styleClass="status-text-warning"/>
    </HBox>
</VBox>
