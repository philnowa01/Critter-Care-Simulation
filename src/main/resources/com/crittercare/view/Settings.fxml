<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crittercare.controller.SettingsController"
      styleClass="view-root" spacing="0">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <!-- Page header -->
    <Label text="Settings" styleClass="page-title"/>
    <Label text="Customize your CritterCare experience"
           styleClass="header-clock"
           style="-fx-padding: 6 0 28 0;"/>

    <!-- Appearance card -->
    <VBox styleClass="panel">
        <padding><Insets top="22" right="22" bottom="24" left="22"/></padding>

        <Label text="APPEARANCE" styleClass="settings-section-header"/>

        <!-- Display mode row -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Display Mode" styleClass="panel-title"/>
                <Label text="Switch between light and dark interface"
                       styleClass="detail-field-label"/>
            </VBox>
            <ToggleButton fx:id="darkModeToggle"
                          styleClass="dark-mode-toggle"
                          onAction="#toggleDarkMode"/>
        </HBox>

        <Separator>
            <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
        </Separator>

        <!-- Color theme row -->
        <VBox spacing="12">
            <Label text="Color Theme" styleClass="panel-title"/>
            <Label text="Choose a sidebar and accent color palette"
                   styleClass="detail-field-label"/>
            <HBox fx:id="themeSwatchRow" spacing="16" alignment="CENTER_LEFT">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </HBox>
        </VBox>

    </VBox>

</VBox>
