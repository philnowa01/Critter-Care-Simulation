<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crittercare.controller.AnimalsController"
      styleClass="view-root" spacing="16">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- ── Toolbar ────────────────────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
        <TextField fx:id="searchField" promptText="🔍  Search by name or species…"
                   prefWidth="280" styleClass="search-field"/>
        <ComboBox fx:id="typeFilter" promptText="All Types" prefWidth="140"
                  styleClass="filter-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnFeed"        text="🍖  Feed"          styleClass="btn-secondary"
                onAction="#feedSelectedAnimal"/>
        <Button fx:id="btnHealthCheck" text="❤  Health Check" styleClass="btn-secondary"
                onAction="#performHealthCheck"/>
        <Button text="+ Add Animal" styleClass="btn-primary" onAction="#showAddAnimalDialog"/>
    </HBox>

    <!-- ── Section heading ────────────────────────────────────────── -->
    <Label text="Animal Registry"
           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>

    <!-- ── Animals table ──────────────────────────────────────────── -->
    <TableView fx:id="animalsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colName"      text="Name"       prefWidth="120"/>
            <TableColumn fx:id="colSpecies"   text="Species"    prefWidth="140"/>
            <TableColumn fx:id="colType"      text="Type"       prefWidth="95"/>
            <TableColumn fx:id="colAge"       text="Age"        prefWidth="55"/>
            <TableColumn fx:id="colHealth"    text="Health"     prefWidth="130"/>
            <TableColumn fx:id="colHunger"    text="Satiation"  prefWidth="130"/>
            <TableColumn fx:id="colHydration" text="Hydration"  prefWidth="130"/>
            <TableColumn fx:id="colEnclosure" text="Enclosure"  prefWidth="130"/>
            <TableColumn fx:id="colStatus"    text="Status"     prefWidth="100"/>
            <TableColumn fx:id="colActions"   text="Actions"    prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No animals found" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status bar ─────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="animalCountLabel"    text="" styleClass="status-text"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="attentionCountLabel" text="" styleClass="status-text-warning"/>
    </HBox>

</VBox>
