<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.crittercare.controller.MainController">

    <!-- ── Sidebar ────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" minWidth="220">

            <!-- Logo -->
            <HBox styleClass="sidebar-logo-area" alignment="CENTER_LEFT" spacing="10">
                <Label text="🐾" styleClass="sidebar-logo-icon"/>
                <VBox spacing="1">
                    <Label text="CritterCare" styleClass="sidebar-logo"/>
                    <Label text="Animal Welfare. Our Priority." styleClass="sidebar-tagline"/>
                </VBox>
            </HBox>

            <!-- Nav -->
            <VBox spacing="2" style="-fx-padding: 10 8 0 8;">
                <Button fx:id="btnDashboard"  text="🏠  Dashboard"
                        styleClass="nav-button" onAction="#showDashboard"
                        maxWidth="Infinity"/>
                <Button fx:id="btnAnimals"    text="🐾  Animals"
                        styleClass="nav-button" onAction="#showAnimals"
                        maxWidth="Infinity"/>
                <Button fx:id="btnEnclosures" text="⊞  Enclosures"
                        styleClass="nav-button" onAction="#showEnclosures"
                        maxWidth="Infinity"/>
                <Button fx:id="btnCareLogs"   text="📋  Care Logs"
                        styleClass="nav-button" onAction="#showCareLogs"
                        maxWidth="Infinity"/>

                <!-- Alerts with badge -->
                <StackPane maxWidth="Infinity">
                    <Button fx:id="btnAlerts" text="🔔  Alerts"
                            styleClass="nav-button" onAction="#showAlerts"
                            maxWidth="Infinity" StackPane.alignment="CENTER_LEFT"/>
                    <Label fx:id="alertBadge" text="" styleClass="alert-badge"
                           visible="false" StackPane.alignment="CENTER_RIGHT">
                        <StackPane.margin><Insets right="14"/></StackPane.margin>
                    </Label>
                </StackPane>

                <Button text="⚙  Settings" styleClass="nav-button" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Simulation status -->
            <VBox styleClass="sim-status-panel" spacing="3">
                <VBox.margin><Insets top="8" right="10" bottom="8" left="10"/></VBox.margin>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label fx:id="simDot"         text="●" styleClass="sim-dot-running"/>
                    <Label fx:id="simStatusLabel" text="Simulation Running" styleClass="sim-status-text"/>
                </HBox>
                <Label fx:id="tickLabel" text="Tick #0" styleClass="sim-tick-label"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <!-- User profile -->
            <HBox styleClass="user-profile-area" alignment="CENTER_LEFT" spacing="10">
                <Label text="AM" styleClass="user-avatar"/>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label text="Alex Morgan" styleClass="user-name"/>
                    <Label text="Zookeeper"   styleClass="user-role"/>
                </VBox>
                <Label text="▾" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 13px;"/>
            </HBox>

        </VBox>
    </left>

    <!-- ── Center ─────────────────────────────────────────────────── -->
    <center>
        <VBox>
            <!-- Header bar -->
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12" prefHeight="64">
                <padding><Insets left="24" right="20"/></padding>
                <Label fx:id="pageTitle" text="Dashboard" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField promptText="🔍  Search animals, enclosures, logs..."
                           styleClass="header-search"/>
                <StackPane>
                    <Button text="🔔" styleClass="header-bell" onAction="#showAlerts"/>
                    <Label fx:id="alertBadge2" text=""
                           styleClass="alert-badge" visible="false"
                           StackPane.alignment="TOP_RIGHT">
                        <StackPane.margin><Insets top="-5" right="-5"/></StackPane.margin>
                    </Label>
                </StackPane>
                <Label fx:id="clockLabel" text="" styleClass="header-clock"/>
            </HBox>

            <!-- Swappable content -->
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS" styleClass="content-area"/>
        </VBox>
    </center>

</BorderPane>
